# Local (proxied via Vite/nginx)
VITE_API_URL=/api/v1
VITE_TELEGRAM_BOT_USERNAME=

# Production (Vercel) — use absolute Railway API URL
# VITE_API_URL=https://your-api.up.railway.app/api/v1
# VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# Dev only — do not set on Vercel (use Telegram login / JWT)
# VITE_INTERNAL_API_KEY=
