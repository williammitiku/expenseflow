# Application
NODE_ENV=development
APP_NAME=ExpenseFlow
APP_URL=http://localhost:8080
APP_PORT=3000
API_PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost
NGINX_PORT=8080
VITE_API_URL=/api/v1
VITE_INTERNAL_API_KEY=change_me_internal_api_key
VITE_TELEGRAM_BOT_USERNAME=

# Database — prefer DATABASE_URL in production (Neon)
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# DB_SSL=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=expenseflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=expenseflow
DB_POOL_MAX=5

# Redis — prefer REDIS_URL in production (Upstash rediss://...)
# REDIS_URL=rediss://default:TOKEN@xxx.upstash.io:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Auth
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=expenseflow
S3_FORCE_PATH_STYLE=true

# Notifications (optional in early phases)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@expenseflow.app
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Service-to-service
INTERNAL_API_KEY=change_me_internal_api_key

# Feature defaults
DEFAULT_CURRENCY=ETB
DEFAULT_TIMEZONE=Africa/Addis_Ababa
